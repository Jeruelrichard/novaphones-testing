# Server
PORT=3000
AUTH_SECRET=change-me-to-a-long-random-string

# Admin login
ADMIN_EMAIL=admin@example.com

# Prefer hashed password for production:
# 1) Run: npm run hash-password
# 2) Paste the printed ADMIN_PASSWORD_SALT and ADMIN_PASSWORD_HASH here
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=

# Dev-only fallback (not recommended for production):
# ADMIN_PASSWORD=your-password-here

# Firebase (recommended for Vercel deployments)
# Use Firestore for product records.
# Provide ONE of:
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_B64=
FIRESTORE_PRODUCTS_COLLECTION=products

# Cloudinary (public image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=novaphones/products
